<!DOCTYPE html>
<html>
<head>
    <title>Feedback Form</title>
</head>
<body>

    <h2 align="center">Feedback Form</h2>

    <form>

        <label>Name:</label><br>
        <input type="text" name="name" required>
        <br><br>

        <label>Email:</label><br>
        <input type="email" name="email" required>
        <br><br>

        <label>Rate Our Service:</label><br>
        <input type="radio" name="rating" value="Excellent"> Excellent
        <input type="radio" name="rating" value="Good"> Good
        <input type="radio" name="rating" value="Average"> Average
        <input type="radio" name="rating" value="Poor"> Poor
        <br><br>

        <label>What did you like?</label><br>
        <input type="checkbox" name="like" value="Design"> Design
        <input type="checkbox" name="like" value="Content"> Content
        <input type="checkbox" name="like" value="Performance"> Performance
        <input type="checkbox" name="like" value="Support"> Support
        <br><br>

        <label>Suggestions:</label><br>
        <textarea rows="5" cols="40" placeholder="Enter your suggestions here..."></textarea>
        <br><br>

        <input type="submit" value="Submit Feedback">
        <input type="reset" value="Clear">

    </form>

</body>
</html>
