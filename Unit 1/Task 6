<!DOCTYPE html>
<html>
<head>
    <title>Image Gallery</title>
</head>
<body>

    <h1>My Image Gallery</h1>

    <figure>
        <img src="nature.jpg" alt="Beautiful green forest" width="300">
        <figcaption>Nature View</figcaption>
    </figure>

    <figure>
        <img src="flower.jpg" alt="Colorful flower in a garden" width="300">
        <figcaption>Flower Garden</figcaption>
    </figure>

    <figure>
        <img src="mountain.jpg" alt="Snow-covered mountain peak" width="300">
        <figcaption>Mountain Scenery</figcaption>
    </figure>

</body>
</html>
