<!DOCTYPE html>
<html>
<head>
    <title>Event Registration Form</title>
</head>
<body>

    <h2 align="center">Event Registration Form</h2>

    <form>

        <label>Participant Name:</label><br>
        <input type="text" name="name" required>
        <br><br>

        <label>Email Address:</label><br>
        <input type="email" name="email" required>
        <br><br>

        <label>Phone Number:</label><br>
        <input type="tel" name="phone" required>
        <br><br>

        <label>College Name:</label><br>
        <input type="text" name="college">
        <br><br>

        <label>Event Name:</label><br>
        <select name="event">
            <option>Technical Quiz</option>
            <option>Paper Presentation</option>
            <option>Web Design Contest</option>
            <option>Coding Competition</option>
            <option>Project Expo</option>
        </select>
        <br><br>

        <label>Gender:</label><br>
        <input type="radio" name="gender" value="Male"> Male
        <input type="radio" name="gender" value="Female"> Female
        <input type="radio" name="gender" value="Other"> Other
        <br><br>

        <label>Skills/Interests:</label><br>
        <input type="checkbox" name="skill" value="Programming"> Programming
        <input type="checkbox" name="skill" value="Web Design"> Web Design
        <input type="checkbox" name="skill" value="Presentation"> Presentation
        <input type="checkbox" name="skill" value="Photography"> Photography
        <br><br>

        <label>Additional Remarks:</label><br>
        <textarea rows="4" cols="40"></textarea>
        <br><br>

        <input type="submit" value="Register">
        <input type="reset" value="Clear Form">

    </form>

</body>
</html>
